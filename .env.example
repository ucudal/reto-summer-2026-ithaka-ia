# Database (local: localhost; Docker: usar host=postgres)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ithaka
# Para docker-compose usar: postgresql+asyncpg://postgres:postgres@postgres:5432/ithaka

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=ithaka

# Auth para endpoints administrativos (documents create/upload/delete)
# Opcion simple:
# ADMIN_API_TOKEN=pon_un_token_largo_y_aleatorio
# Opcion con roles (formato token:rol separados por coma):
# AUTH_TOKENS=token_admin_1:admin,token_lector_1:reader

# External Ithaka API (for wizard postulation submission)
ITHAKA_API_BASE_URL=http://localhost:8000

# Other environment variables (add as needed)
# TWILIO_ACCOUNT_SID=your_twilio_sid
# TWILIO_AUTH_TOKEN=your_twilio_token
